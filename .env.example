# ─── FlowSync Backend Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flowsync
DB_ECHO=false

# Google APIs
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Weather API
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Firebase Admin SDK (for push notifications)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# SendGrid (email alerts)
SENDGRID_API_KEY=your_sendgrid_api_key_here
ALERT_EMAIL_FROM=alerts@flowsync.io

# App Config
MOCK_MODE=true
SIMULATE_MOVEMENT=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# GCP (optional, for Cloud Run deployment)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
